{
    "name": "allyoullneed/advanced-controls",
    "description": "UI components for Statamic, powered by Livewire 4",
    "require": {
        "blade-ui-kit/blade-icons": "^1.8",
        "illuminate/support": "^12"
    },
    "require-dev": {
        "pestphp/pest": "^4"
    },
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "AllYoullNeed\\AdvancedControls\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AllYoullNeed\\AdvancedControls\\AdvancedControlsServiceProvider"
            ],
            "aliases": {
                "AdvancedControls": "AllYoullNeed\\AdvancedControls\\Facades\\AdvancedControls"
            }
        }
    },
    "minimum-stability": "beta",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
