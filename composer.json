{
    "name": "allyouneed/advanced-controls",
    "description": "UI components for Statamic, powered by Livewire 4",
    "require": {
        "blade-ui-kit/blade-icons": "^1.8",
        "gehrisandro/tailwind-merge-laravel": "^1.3",
        "livewire/livewire": "^4"
    },
    "require-dev": {
        "pestphp/pest": "^4"
    },
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "AdvancedControls\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AdvancedControls\\AdvancedControlsServiceProvider"
            ],
            "aliases": {
                "AdvancedControls": "AdvancedControls\\facades\\AdvancedControls"
            }
        }
    },
    "minimum-stability": "beta"
}
