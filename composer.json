{
    "name": "allyouneed/advanced-controls",
    "description": "UI components for Statamic, powered by Livewire 4",
    "require": {
        "blade-ui-kit/blade-icons": "^1.8",
        "gehrisandro/tailwind-merge-laravel": "^1.3",
        "livewire/livewire": "^4",
        "illuminate/support": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4"
    },
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "AllYouNeed\\AdvancedControls\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AllYouNeed\\AdvancedControls\\AdvancedControlsServiceProvider"
            ],
            "aliases": {
                "AdvancedControls": "AllYouNeed\\AdvancedControls\\facades\\AdvancedControls"
            }
        }
    },
    "minimum-stability": "beta",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
